{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:android": "node scripts/validate-android-api-url.mjs && vite build",
    "android:add": "cap add android",
    "android:sync": "npm run build:android && cap sync android",
    "android:open": "cap open android",
    "lint": "echo 'lint pendente frontend'",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173} --strictPort"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "@types/node": "^22.13.10"
  }
}
